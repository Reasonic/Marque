node_modules/
*.log
.DS_Store
.env
.env.*
coverage/
dist/
*.tgz

# Fixture PDFs are fetched, not committed — see bench/fetch-fixtures.sh
bench/fixtures/*.pdf

# Type declarations are emitted at pack time (prepack), not committed.
types/

# Deterministic benchmark output — regenerated by `npm run bench:structure-accuracy`;
# its exact contents depend on which PDFs are present locally, so it is not committed.
bench/structure-accuracy-results.json

# FinanceBench data is fetched, not committed (Patronus AI's data + SEC filings).
bench/financebench/data/
bench/financebench/pdfs/
bench/financebench/results*.json

# RAPTOR head-to-head (working dirs + outputs, never committed)
bench/financebench/raptor/
bench/financebench/raptor-venv/
bench/financebench/results-raptor*.json
