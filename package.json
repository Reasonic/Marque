{
  "name": "vectorless-rag",
  "version": "0.0.0",
  "description": "Vectorless RAG — structure-first document indexing without a vector DB",
  "main": "src/index.mjs",
  "types": "./types/index.d.mts",
  "exports": {
    ".": {
      "types": "./types/index.d.mts",
      "import": "./src/index.mjs"
    }
  },
  "scripts": {
    "test": "node --test 'test/*.test.mjs'",
    "bench": "node bench/query-cost.mjs bench/fixtures/*.pdf",
    "eval": "node bench/retrieval-eval.mjs",
    "fixtures": "./bench/fetch-fixtures.sh",
    "lint": "eslint .",
    "build:types": "tsc -p tsconfig.json",
    "clean:types": "rm -rf types",
    "prepack": "npm run build:types"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/openai": "^4.0.16",
    "ai": "^7.0.32",
    "gpt-tokenizer": "^3.4.0",
    "pdfjs-dist": "^6.1.200",
    "zod": "^4.4.3"
  },
  "bin": {
    "vectorless": "bin/cli.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src",
    "bin",
    "types",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^7.0.2"
  }
}
