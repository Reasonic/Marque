{
  "name": "marque-rag",
  "version": "0.3.1",
  "description": "Marque — structure-first document indexing for RAG, without a vector database",
  "main": "src/index.mjs",
  "types": "./types/index.d.mts",
  "exports": {
    ".": {
      "types": "./types/index.d.mts",
      "import": "./src/index.mjs"
    }
  },
  "scripts": {
    "test": "node --test 'test/*.test.mjs'",
    "test:live": "node --test 'test/live/*.test.mjs'",
    "bench": "node bench/query-cost.mjs bench/fixtures/*.pdf",
    "bench:structure-cost": "node bench/structure-cost.mjs",
    "bench:structure-accuracy": "node bench/structure-accuracy.mjs",
    "bench:significance": "node bench/financebench/significance.mjs",
    "bench:qasper": "node --env-file=.env bench/qasper/run.mjs",
    "bench:non-pdf": "node bench/non-pdf.mjs",
    "bench:all": "node bench/all.mjs",
    "eval": "node bench/retrieval-eval.mjs",
    "fixtures": "./bench/fetch-fixtures.sh",
    "lint": "eslint .",
    "build:types": "tsc -p tsconfig.json",
    "clean:types": "rm -rf types",
    "prepack": "npm run build:types"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/openai": "^4.0.16",
    "ai": "^7.0.32",
    "gpt-tokenizer": "^3.4.0",
    "pdfjs-dist": "^6.1.200",
    "zod": "^4.4.3"
  },
  "bin": {
    "marque": "bin/cli.mjs",
    "marque-rag": "bin/cli.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src",
    "bin",
    "types",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^7.0.2"
  }
}
